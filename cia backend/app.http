@baseUrl = http://127.0.0.1:8000

### 1) Register new user (should return 201)
POST {{baseUrl}}/register
Content-Type: application/json

{
  "username": "bhuvana",
  "email": "bhuva@example.com",
  "password": "secret123"
}

### 2) Register same email again (should return 409)
POST {{baseUrl}}/register
Content-Type: application/json

{
  "username": "john_doe_2",
  "email": "john@example.com",
  "password": "secret123"
}

### 3) Invalid register data (should return 422)
POST {{baseUrl}}/register
Content-Type: application/json

{
  "username": "ab",
  "email": "not-an-email",
  "password": "123"
}

### 4) Login success (should return 200)
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "john@example.com",
  "password": "secret123"
}

### 5) Login wrong password (should return 401)
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "john@example.com",
  "password": "wrongpass"
}

### 6) Login unknown user (should return 401)
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "unknown@example.com",
  "password": "secret123"
}

### 7) Execute on test cases and return score (all pass)
POST {{baseUrl}}/code/execute
Content-Type: application/json

{
  "source_code": "n = int(input())\nprint(n * 2)",
  "language_id": 71,
  "test_cases": [
    {
      "input": "2\n",
      "expected_output": "4",
      "weight": 1
    },
    {
      "input": "5\n",
      "expected_output": "10",
      "weight": 1
    },
    {
      "input": "9\n",
      "expected_output": "18",
      "weight": 1
    }
  ]
}

### 8) Execute code once (stdin/stdout)
POST {{baseUrl}}/code/run
Content-Type: application/json

{
  "source_code": "name = input().strip()\nprint(f'Hello, {name}!')",
  "language_id": 71,
  "stdin": "Codex"
}

### 9) Execute on test cases and return score (partial pass)
POST {{baseUrl}}/code/execute
Content-Type: application/json

{
  "source_code": "n = int(input())\nprint(n + 1)",
  "language_id": 71,
  "test_cases": [
    {
      "input": "2\n",
      "expected_output": "3",
      "weight": 1
    },
    {
      "input": "5\n",
      "expected_output": "6",
      "weight": 2
    }
  ]
}

### 10) Generate 5 interview questions
POST {{baseUrl}}/interview/questions

### 11) Generate interview feedback from score
POST {{baseUrl}}/interview/feedback
Content-Type: application/json

{
  "score": 36
}
